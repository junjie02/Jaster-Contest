# Optional runtime tuning
JASTER_DATA_DIR=./data
JASTER_MAX_ROUNDS=200

# Optional HTTP behavior for future integrations
# http 超时（秒）
JASTER_HTTP_TIMEOUT=120
# llm agent 层重试次数（JSON 解析 / schema 校验失败时，不重试 5xx）
JASTER_LLM_MAX_RETRIES=1000
# HTTP 层重试次数（429 / 5xx / 网络错误）
JASTER_LLM_HTTP_MAX_RETRIES=3
# HTTP 重试指数退避基数（秒）
JASTER_LLM_HTTP_RETRY_BASE_DELAY=1.0
# HTTP 重试指数退避上限（秒）
JASTER_LLM_HTTP_RETRY_MAX_DELAY=8.0
# HTTP 重试退避抖动幅度（秒）
JASTER_LLM_HTTP_RETRY_JITTER=0.2
# LLM 请求节流：窗口内最大请求数
JASTER_LLM_RATE_LIMIT_MAX_REQUESTS=2
# LLM 请求节流窗口（秒）
JASTER_LLM_RATE_LIMIT_WINDOW_SECONDS=1.0
