# ----------------------------------------------------------------------
# Jaster environment
# Copy this file as-is and replace placeholder values as needed.
# ----------------------------------------------------------------------

# OpenAI-compatible LLM API
OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional runtime tuning
JASTER_DATA_DIR=./data
JASTER_MAX_RECON_STEPS=3
JASTER_MAX_ROUNDS=12

# Optional HTTP behavior for future integrations
JASTER_HTTP_TIMEOUT=120
JASTER_LLM_MAX_RETRIES=3

