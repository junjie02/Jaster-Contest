{
  "name": "port_scan",
  "bin": "nmap",
  "description": "Run nmap for structured port and service discovery.",
  "base_argv": [
    "-Pn",
    "-n"
  ],
  "primary_locator_arg": "target",
  "shape_signature_args": [
    "target",
    "ports",
    "top_ports"
  ],
  "variant_signature_args": [
    "target",
    "ports",
    "top_ports",
    "service_detection",
    "default_scripts",
    "aggressive",
    "timing",
    "min_rate",
    "output_prefix"
  ],
  "args": [
    {
      "name": "service_detection",
      "type": "bool",
      "flag": "-sV",
      "description": "Enable service version detection"
    },
    {
      "name": "default_scripts",
      "type": "bool",
      "flag": "-sC",
      "description": "Run default NSE scripts"
    },
    {
      "name": "aggressive",
      "type": "bool",
      "flag": "-A",
      "description": "Enable aggressive scan"
    },
    {
      "name": "ports",
      "type": "string",
      "flag": "-p",
      "description": "Port list or ranges"
    },
    {
      "name": "top_ports",
      "type": "int",
      "flag": "--top-ports",
      "description": "Scan top N ports"
    },
    {
      "name": "timing",
      "type": "string",
      "flag": "-T",
      "description": "Timing template, e.g. 4"
    },
    {
      "name": "min_rate",
      "type": "int",
      "flag": "--min-rate",
      "description": "Minimum packet rate"
    },
    {
      "name": "output_prefix",
      "type": "string",
      "flag": "-oA",
      "path_policy": "work_dir_output",
      "description": "Output prefix within work dir"
    },
    {
      "name": "target",
      "type": "string",
      "required": true,
      "position": 100,
      "description": "Target host or range"
    }
  ],
  "examples": [
    {
      "label": "ports",
      "skill_args": {
        "target": "10.10.10.10",
        "ports": "22,80,443",
        "service_detection": true,
        "default_scripts": true
      }
    },
    {
      "label": "top_ports",
      "skill_args": {
        "target": "10.10.10.10",
        "top_ports": 1000,
        "timing": "4",
        "output_prefix": "nmap_top1000"
      }
    }
  ],
  "summary": "使用 `nmap` 做端口、服务和基础脚本侦察。",
  "use_when": "需要确认目标开放了哪些端口和服务。 需要给后续 Web、SMB、LDAP、RDP 等路径找入口。 需要在 TCP 题或主机题首轮快速建立资产面。",
  "command_mode": "argv"
}
