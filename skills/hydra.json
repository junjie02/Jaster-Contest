{
  "name": "hydra",
  "bin": "hydra",
  "description": "使用 hydra 进行常见服务（SSH、FTP、MySQL、RDP、SMB 等）的暴力破解。",
  "base_argv": [
    "-V"
  ],
  "primary_locator_arg": "target",
  "shape_signature_args": [
    "target",
    "service",
    "username",
    "user_file",
    "password_file"
  ],
  "variant_signature_args": [
    "target",
    "service",
    "username",
    "user_file",
    "password_file",
    "port",
    "verbose",
    "output_file"
  ],
  "args": [
    {
      "name": "target",
      "type": "string",
      "required": true,
      "position": 100,
      "description": "目标 IP 或主机名"
    },
    {
      "name": "service",
      "type": "string",
      "required": true,
      "position": 101,
      "description": "服务类型，如 ssh、ftp、mysql、rdp、smb 等；HTTP表单使用完整URL格式：http-post-form://host/uri:user_field:pass_field:condition"
    },
    {
      "name": "username",
      "type": "string",
      "flag": "-l",
      "description": "单个用户名（与 user_file 二选一）"
    },
    {
      "name": "user_file",
      "type": "string",
      "flag": "-L",
      "description": "用户名列表文件路径（与 username 二选一）"
    },
    {
      "name": "password_file",
      "type": "string",
      "flag": "-P",
      "required": true,
      "description": "密码字典文件路径"
    },
    {
      "name": "port",
      "type": "int",
      "flag": "-s",
      "description": "目标端口（当非默认端口时指定）"
    },
    {
      "name": "verbose",
      "type": "bool",
      "flag": "-V",
      "description": "显示每个尝试的详情"
    },
    {
      "name": "output_file",
      "type": "string",
      "flag": "-o",
      "path_policy": "work_dir_output",
      "description": "结果输出文件（保存在 work_dir 下）"
    }
  ],
  "examples": [
    {
      "label": "SSH单用户爆破",
      "skill_args": {
        "target": "10.10.10.10",
        "service": "ssh",
        "username": "root",
        "password_file": "/usr/share/wordlists/rockyou.txt",
        "verbose": true
      }
    },
    {
      "label": "FTP用户名列表爆破",
      "skill_args": {
        "target": "10.10.10.10",
        "service": "ftp",
        "user_file": "./users.txt",
        "password_file": "/usr/share/wordlists/rockyou.txt"
      }
    },
    {
      "label": "MySQL暴力破解",
      "skill_args": {
        "target": "10.10.10.10",
        "service": "mysql",
        "username": "root",
        "password_file": "/usr/share/wordlists/rockyou.txt"
      }
    },
    {
      "label": "RDP暴力破解",
      "skill_args": {
        "target": "10.10.10.10",
        "service": "rdp",
        "username": "Administrator",
        "password_file": "/usr/share/wordlists/rockyou.txt"
      }
    },
    {
      "label": "HTTP表单爆破",
      "skill_args": {
        "target": "10.10.10.10",
        "service": "http-post-form",
        "username": "admin",
        "password_file": "/usr/share/wordlists/rockyou.txt"
      }
    }
  ],
  "summary": "使用 `hydra` 对 SSH、FTP、MySQL、RDP、SMB 等常见服务进行暴力破解或密码 spraying。HTTP表单爆破需使用完整URL格式。用户名字典：/home/painting/桌面/Jaster/skills/docs/username.txt；密码字典：/home/painting/桌面/Jaster/skills/docs/password.txt。示例：hydra -L username.txt -P password.txt target.com http-post-form ‘/api/login:username=^USER^&password=^PASS^:错误密码|用户名不存在’ -V -t 4 -w 10",
  "use_when": "已确认目标开放了 SSH/FTP/MySQL/RDP/SMB 等服务，需要获取有效凭据。 HTTP 表单爆破适用于已知登录入口且知道失败关键词的场景。当前字典十分轻量，高信息增益",
  "command_mode": "argv"
}
