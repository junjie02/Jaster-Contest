{
  "name": "wpscan",
  "bin": "wpscan",
  "description": "Run WPScan with structured enumeration options.",
  "base_argv": [
    "-f",
    "json"
  ],
  "primary_locator_arg": "url",
  "shape_signature_args": [
    "url",
    "enumerate"
  ],
  "variant_signature_args": [
    "url",
    "enumerate",
    "detection_mode",
    "plugins_detection",
    "plugins_version_detection",
    "random_user_agent",
    "disable_tls_checks",
    "threads",
    "throttle"
  ],
  "args": [
    {
      "name": "url",
      "type": "string",
      "flag": "--url",
      "required": true,
      "description": "Target URL"
    },
    {
      "name": "enumerate",
      "type": "string",
      "flag": "-e",
      "required": true,
      "description": "Enumeration items"
    },
    {
      "name": "detection_mode",
      "type": "string",
      "flag": "--detection-mode",
      "enum": [
        "mixed",
        "passive",
        "aggressive"
      ],
      "description": "Global detection mode"
    },
    {
      "name": "plugins_detection",
      "type": "string",
      "flag": "--plugins-detection",
      "description": "Plugin detection strength"
    },
    {
      "name": "plugins_version_detection",
      "type": "string",
      "flag": "--plugins-version-detection",
      "description": "Plugin version detection strength"
    },
    {
      "name": "random_user_agent",
      "type": "bool",
      "flag": "--random-user-agent",
      "description": "Use random UA"
    },
    {
      "name": "disable_tls_checks",
      "type": "bool",
      "flag": "--disable-tls-checks",
      "description": "Disable TLS checks"
    },
    {
      "name": "threads",
      "type": "int",
      "flag": "-t",
      "description": "Thread count"
    },
    {
      "name": "throttle",
      "type": "int",
      "flag": "--throttle",
      "description": "Throttle in ms"
    }
  ],
  "examples": [
    {
      "label": "vp_vt_u",
      "skill_args": {
        "url": "http://blog.local",
        "enumerate": "vp,vt,u"
      }
    },
    {
      "label": "plugins",
      "skill_args": {
        "url": "http://blog.local",
        "enumerate": "ap",
        "plugins_detection": "mixed",
        "plugins_version_detection": "mixed",
        "random_user_agent": true
      }
    }
  ],
  "summary": "使用 `wpscan` 做 WordPress 站点的插件、主题、用户和常见弱点枚举。",
  "use_when": "目标已经明确是 WordPress。 需要快速确认插件、主题、用户、备份或公开弱点线索。 想先拿到 WP 画像，再决定是否继续专项利用。",
  "command_mode": "argv"
}
