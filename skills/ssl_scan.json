{
  "name": "ssl_scan",
  "bin": "sslscan",
  "description": "Inspect TLS versions, certificates and ciphers.",
  "base_argv": [],
  "primary_locator_arg": "target",
  "shape_signature_args": [
    "target",
    "sni_name"
  ],
  "variant_signature_args": [
    "target",
    "show_certificate",
    "show_ciphers",
    "tls12",
    "tls13",
    "tlsall",
    "sni_name",
    "starttls_ldap",
    "timeout",
    "xml_output"
  ],
  "args": [
    {
      "name": "show_certificate",
      "type": "bool",
      "flag": "--show-certificate",
      "description": "Show certificate details"
    },
    {
      "name": "show_ciphers",
      "type": "bool",
      "flag": "--show-ciphers",
      "description": "Show supported ciphers"
    },
    {
      "name": "tls12",
      "type": "bool",
      "flag": "--tls12",
      "description": "Only test TLS 1.2"
    },
    {
      "name": "tls13",
      "type": "bool",
      "flag": "--tls13",
      "description": "Only test TLS 1.3"
    },
    {
      "name": "tlsall",
      "type": "bool",
      "flag": "--tlsall",
      "description": "Test all TLS versions"
    },
    {
      "name": "sni_name",
      "type": "string",
      "flag": "--sni-name",
      "description": "SNI hostname"
    },
    {
      "name": "starttls_ldap",
      "type": "bool",
      "flag": "--starttls-ldap",
      "description": "Use LDAP STARTTLS"
    },
    {
      "name": "timeout",
      "type": "int",
      "flag": "--timeout",
      "description": "Timeout in seconds"
    },
    {
      "name": "xml_output",
      "type": "string",
      "flag": "--xml",
      "path_policy": "work_dir_output",
      "description": "XML output file"
    },
    {
      "name": "target",
      "type": "string",
      "required": true,
      "position": 100,
      "description": "host:port target"
    }
  ],
  "examples": [
    {
      "label": "basic",
      "skill_args": {
        "target": "target.local:443"
      }
    },
    {
      "label": "full",
      "skill_args": {
        "target": "10.10.10.20:8443",
        "sni_name": "target.local",
        "show_certificate": true,
        "tlsall": true
      }
    }
  ],
  "summary": "使用 `sslscan` 检查 TLS 版本、证书和加密套件配置。",
  "use_when": "目标开放 HTTPS 或其它 TLS 服务。 需要确认协议版本、证书和明显弱配置。 需要验证 443、8443、636、993、995 等端口上是否真是 TLS 服务。",
  "command_mode": "argv"
}
