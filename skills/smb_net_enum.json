{
  "name": "smb_net_enum",
  "bin": "netexec",
  "description": "Run netexec smb with structured enumeration flags.",
  "base_argv": [
    "smb"
  ],
  "primary_locator_arg": "target",
  "shape_signature_args": [
    "target",
    "domain",
    "username"
  ],
  "variant_signature_args": [
    "target",
    "username",
    "password",
    "hash",
    "domain",
    "k",
    "shares",
    "users",
    "groups",
    "pass_pol"
  ],
  "args": [
    {
      "name": "username",
      "type": "string",
      "flag": "-u",
      "description": "Username"
    },
    {
      "name": "password",
      "type": "string",
      "flag": "-p",
      "description": "Password"
    },
    {
      "name": "hash",
      "type": "string",
      "flag": "-H",
      "description": "NTLM hash"
    },
    {
      "name": "domain",
      "type": "string",
      "flag": "-d",
      "description": "Domain name"
    },
    {
      "name": "k",
      "type": "bool",
      "flag": "-k",
      "description": "Use Kerberos"
    },
    {
      "name": "shares",
      "type": "bool",
      "flag": "--shares",
      "description": "Enumerate shares"
    },
    {
      "name": "users",
      "type": "bool",
      "flag": "--users",
      "description": "Enumerate users"
    },
    {
      "name": "groups",
      "type": "bool",
      "flag": "--groups",
      "description": "Enumerate groups"
    },
    {
      "name": "pass_pol",
      "type": "bool",
      "flag": "--pass-pol",
      "description": "Show password policy"
    },
    {
      "name": "target",
      "type": "string",
      "required": true,
      "position": 100,
      "description": "Host, CIDR or target file"
    }
  ],
  "examples": [
    {
      "label": "guest",
      "skill_args": {
        "target": "10.10.10.30",
        "username": "guest",
        "password": "",
        "shares": true
      }
    },
    {
      "label": "domain",
      "skill_args": {
        "target": "10.10.10.30",
        "domain": "corp.local",
        "username": "alice",
        "password": "Passw0rd!",
        "shares": true,
        "users": true,
        "groups": true,
        "pass_pol": true
      }
    }
  ],
  "summary": "使用 `netexec smb` 对 SMB 主机做共享、用户、组和基础权限枚举。",
  "use_when": "目标开放 445，需要先确认 SMB 资产面。 已有匿名、弱口令、哈希或域凭据，想快速验证能看到什么。 需要给后续横向、票据或凭据导出补上下文。",
  "command_mode": "argv"
}
