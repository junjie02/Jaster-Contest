{
  "name": "ffuf_bruteforce",
  "bin": "ffuf",
  "description": "Run ffuf for password brute-forcing against HTTP login endpoints.",
  "primary_locator_arg": "url",
  "shape_signature_args": [
    "url",
    "wordlist"
  ],
  "variant_signature_args": [
    "url",
    "wordlist",
    "match_codes",
    "filter_codes",
    "match_size",
    "filter_size",
    "threads",
    "rate",
    "headers"
  ],
  "args": [
    {
      "name": "url",
      "type": "string",
      "flag": "-u",
      "required": true,
      "description": "Target URL (must include http/https)"
    },
    {
      "name": "wordlist",
      "type": "string",
      "flag": "-w",
      "required": true,
      "description": "Password wordlist (use FUZZ placeholder)"
    },
    {
      "name": "method",
      "type": "string",
      "flag": "-X",
      "default": "POST"
    },
    {
      "name": "data",
      "type": "string",
      "flag": "-d",
      "description": "Request body using FUZZ (e.g. username=admin&password=FUZZ)"
    },
    {
      "name": "headers",
      "type": "string_list",
      "flag": "-H",
      "repeatable": true,
      "description": "Extra headers (e.g. Content-Type: application/json)"
    },
    {
      "name": "match_codes",
      "type": "string",
      "flag": "-mc"
    },
    {
      "name": "filter_codes",
      "type": "string",
      "flag": "-fc"
    },
    {
      "name": "match_size",
      "type": "string",
      "flag": "-ms"
    },
    {
      "name": "filter_size",
      "type": "string",
      "flag": "-fs"
    },
    {
      "name": "match_regex",
      "type": "string",
      "flag": "-mr"
    },
    {
      "name": "filter_regex",
      "type": "string",
      "flag": "-fr"
    },
    {
      "name": "threads",
      "type": "int",
      "flag": "-t",
      "default": 20
    },
    {
      "name": "rate",
      "type": "int",
      "flag": "-rate"
    },
    {
      "name": "follow_redirects",
      "type": "bool",
      "flag": "-r"
    },
    {
      "name": "wait",
      "type": "int",
      "flag": "-p",
      "description": "Delay between requests (seconds)"
    }
  ],

  "examples": [
    {
      "label": "basic_form_login",
      "skill_args": {
        "url": "http://target.local/login",
        "wordlist": "/usr/share/wordlists/rockyou.txt",
        "data": "username=admin&password=FUZZ",
        "filter_size": "1234"
      }
    },
    {
      "label": "json_login",
      "skill_args": {
        "url": "http://target.local/api/login",
        "wordlist": "/usr/share/wordlists/rockyou.txt",
        "method": "POST",
        "data": "{\"username\":\"admin\",\"password\":\"FUZZ\"}",
        "headers": ["Content-Type: application/json"],
        "match_codes": "200"
      }
    }
  ],

  "summary": "使用 ffuf 对登录接口进行密码爆破，使用 FUZZ 作为占位符。",
  "use_when": "已确认登录接口，且用户名已知（如 admin），需要进行密码爆破。示例：ffuf -w /home/painting/桌面/Jaster/skills/docs/password.txt -X POST -d 'username=admin&password=FUZZ' -u http://target/login -fs 1234",
  "command_mode": "argv"
}