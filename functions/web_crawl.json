{
  "name": "web_crawl",
  "bin": "curl",
  "description": "Fetch a web page with structured HTTP parameters.",
  "base_argv": [
    "-sSkL"
  ],
  "primary_locator_arg": "url",
  "shape_signature_args": [
    "url",
    "method",
    "headers_only"
  ],
  "variant_signature_args": [
    "url",
    "method",
    "data",
    "headers",
    "cookie",
    "user_agent",
    "headers_only"
  ],
  "args": [
    {
      "name": "headers",
      "type": "string_list",
      "flag": "-H",
      "repeatable": true,
      "description": "Extra HTTP headers"
    },
    {
      "name": "user_agent",
      "type": "string",
      "flag": "-A",
      "description": "User-Agent header"
    },
    {
      "name": "cookie",
      "type": "string",
      "flag": "-b",
      "description": "Cookie header"
    },
    {
      "name": "method",
      "type": "string",
      "flag": "-X",
      "description": "HTTP method"
    },
    {
      "name": "data",
      "type": "string",
      "flag": "-d",
      "description": "POST body"
    },
    {
      "name": "headers_only",
      "type": "bool",
      "flag": "-I",
      "description": "Fetch headers only"
    },
    {
      "name": "output_file",
      "type": "string",
      "flag": "-o",
      "path_policy": "work_dir_output",
      "description": "Save response to work dir"
    },
    {
      "name": "url",
      "type": "string",
      "required": true,
      "position": 100,
      "description": "Target URL"
    }
  ],
  "examples": [
    {
      "label": "basic",
      "skill_args": {
        "url": "http://target.local"
      }
    },
    {
      "label": "with_cookie",
      "skill_args": {
        "url": "http://target.local/login",
        "headers": [
          "User-Agent: Mozilla/5.0"
        ],
        "cookie": "PHPSESSID=demo"
      }
    }
  ],
  "summary": "使用 `curl` 等低成本抓取命令提取页面中的链接、脚本、表单和隐藏字段。",
  "use_when": "需要快速抓首页或关键入口页的表层内容。 需要先看 href、src、form、注释、隐藏字段等线索。 不需要登录流程自动化或跨页面复杂爬取。对于http目标前期的必须探测。",
  "command_mode": "argv"
}
