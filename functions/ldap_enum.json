{
  "name": "ldap_enum",
  "bin": "ldapsearch",
  "description": "Query LDAP objects with a structured base DN and filter.",
  "base_argv": [],
  "primary_locator_arg": "uri",
  "shape_signature_args": [
    "uri",
    "base_dn",
    "filter"
  ],
  "variant_signature_args": [
    "uri",
    "simple_auth",
    "bind_dn",
    "password",
    "base_dn",
    "scope",
    "lll",
    "starttls",
    "nettimeout",
    "attributes_only",
    "filter",
    "attributes"
  ],
  "args": [
    {
      "name": "simple_auth",
      "type": "bool",
      "flag": "-x",
      "default": true,
      "description": "Use simple auth"
    },
    {
      "name": "uri",
      "type": "string",
      "flag": "-H",
      "required": true,
      "description": "LDAP URI"
    },
    {
      "name": "bind_dn",
      "type": "string",
      "flag": "-D",
      "description": "Bind DN"
    },
    {
      "name": "password",
      "type": "string",
      "flag": "-w",
      "description": "Bind password"
    },
    {
      "name": "base_dn",
      "type": "string",
      "flag": "-b",
      "required": true,
      "description": "Base DN"
    },
    {
      "name": "scope",
      "type": "string",
      "flag": "-s",
      "default": "sub",
      "enum": [
        "base",
        "one",
        "sub"
      ],
      "description": "Search scope"
    },
    {
      "name": "lll",
      "type": "bool",
      "flag": "-LLL",
      "default": true,
      "description": "Compact LDIF output"
    },
    {
      "name": "starttls",
      "type": "bool",
      "flag": "-ZZ",
      "description": "Use StartTLS"
    },
    {
      "name": "nettimeout",
      "type": "string",
      "flag": "-o",
      "description": "ldapsearch -o value, e.g. nettimeout=5"
    },
    {
      "name": "attributes_only",
      "type": "bool",
      "flag": "-A",
      "description": "Show attribute names only"
    },
    {
      "name": "filter",
      "type": "string",
      "required": true,
      "position": 100,
      "description": "LDAP filter"
    },
    {
      "name": "attributes",
      "type": "string_list",
      "position": 200,
      "repeatable": true,
      "description": "Attributes to return"
    }
  ],
  "examples": [
    {
      "label": "people",
      "skill_args": {
        "uri": "ldap://10.10.10.40:389",
        "base_dn": "DC=corp,DC=local",
        "filter": "(objectClass=person)",
        "attributes": [
          "cn",
          "sAMAccountName",
          "mail"
        ]
      }
    },
    {
      "label": "computers",
      "skill_args": {
        "uri": "ldap://10.10.10.40:389",
        "base_dn": "DC=corp,DC=local",
        "filter": "(objectClass=computer)",
        "attributes": [
          "dNSHostName",
          "operatingSystem"
        ]
      }
    }
  ],
  "summary": "使用 `ldapsearch` 查询目录对象、用户、组、主机和基础域信息。",
  "use_when": "目标是 AD / LDAP 环境，需要补齐目录对象画像。 已知 base DN，想定向查用户、组、主机或 OU。 需要把 LDAP 结果和 SMB、Kerberos 结果交叉验证。",
  "command_mode": "argv"
}
