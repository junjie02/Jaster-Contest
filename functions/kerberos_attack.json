{
  "name": "kerberos_attack",
  "bin": "GetNPUsers.py",
  "description": "Collect AS-REP Roast or Kerberoast material with structured Kerberos options.",
  "base_argv": [],
  "primary_locator_arg": "target",
  "shape_signature_args": [
    "roast_mode",
    "target",
    "dc_ip"
  ],
  "variant_signature_args": [
    "roast_mode",
    "target",
    "dc_ip",
    "dc_host",
    "usersfile",
    "request",
    "outputfile",
    "format",
    "hashes",
    "no_pass",
    "k",
    "aesKey"
  ],
  "bin_selector_arg": "roast_mode",
  "bin_map": {
    "asrep": "GetNPUsers.py",
    "kerberoast": "GetUserSPNs.py"
  },
  "args": [
    {
      "name": "roast_mode",
      "type": "string",
      "required": true,
      "default": "asrep",
      "enum": [
        "asrep",
        "kerberoast"
      ],
      "description": "Kerberos roast mode"
    },
    {
      "name": "dc_ip",
      "type": "string",
      "flag": "-dc-ip",
      "description": "Domain controller IP"
    },
    {
      "name": "dc_host",
      "type": "string",
      "flag": "-dc-host",
      "description": "Domain controller host"
    },
    {
      "name": "usersfile",
      "type": "string",
      "flag": "-usersfile",
      "path_policy": "repo_relative",
      "description": "Username list"
    },
    {
      "name": "request",
      "type": "bool",
      "flag": "-request",
      "default": true,
      "description": "Request roast material"
    },
    {
      "name": "outputfile",
      "type": "string",
      "flag": "-outputfile",
      "path_policy": "work_dir_output",
      "description": "Output file"
    },
    {
      "name": "format",
      "type": "string",
      "flag": "-format",
      "enum": [
        "hashcat",
        "john"
      ],
      "description": "Output format"
    },
    {
      "name": "hashes",
      "type": "string",
      "flag": "-hashes",
      "description": "LMHASH:NTHASH"
    },
    {
      "name": "no_pass",
      "type": "bool",
      "flag": "-no-pass",
      "description": "Do not prompt for password"
    },
    {
      "name": "k",
      "type": "bool",
      "flag": "-k",
      "description": "Use Kerberos authentication"
    },
    {
      "name": "aesKey",
      "type": "string",
      "flag": "-aesKey",
      "description": "AES key"
    },
    {
      "name": "target",
      "type": "string",
      "required": true,
      "position": 100,
      "description": "domain/user:pass or domain/"
    }
  ],
  "examples": [
    {
      "label": "asrep",
      "skill_args": {
        "roast_mode": "asrep",
        "target": "corp.local/",
        "dc_ip": "10.10.10.10",
        "usersfile": "functions/docs/users.txt",
        "outputfile": "asrep.txt",
        "format": "hashcat"
      }
    },
    {
      "label": "kerberoast",
      "skill_args": {
        "roast_mode": "kerberoast",
        "target": "corp.local/user:Passw0rd!",
        "dc_ip": "10.10.10.10",
        "outputfile": "kerberoast.txt"
      }
    }
  ],
  "summary": "使用 Impacket 的 Kerberos roast 工具提取 AS-REP Roast 或 Kerberoast 材料。",
  "use_when": "目标是 AD / Kerberos 环境。 已拿到用户名单但还没有有效域凭据，想先检查是否存在“不需要预认证”的账户，此时优先 `GetNPUsers.py`。 已有低权域账号，想拉取配置了 SPN 的服务账户票据材料，此时优先 `GetUserSPNs.py`。",
  "command_mode": "argv"
}
