{
  "name": "cred_dump",
  "bin": "impacket-secretsdump",
  "description": "Dump credentials from a host or domain controller with structured options.",
  "base_argv": [],
  "primary_locator_arg": "target",
  "shape_signature_args": [
    "target",
    "dc_ip"
  ],
  "variant_signature_args": [
    "target",
    "hashes",
    "no_pass",
    "k",
    "aesKey",
    "dc_ip",
    "just_dc",
    "just_dc_user",
    "outputfile",
    "use_vss"
  ],
  "args": [
    {
      "name": "hashes",
      "type": "string",
      "flag": "-hashes",
      "description": "LMHASH:NTHASH"
    },
    {
      "name": "no_pass",
      "type": "bool",
      "flag": "-no-pass",
      "description": "Do not prompt for password"
    },
    {
      "name": "k",
      "type": "bool",
      "flag": "-k",
      "description": "Use Kerberos"
    },
    {
      "name": "aesKey",
      "type": "string",
      "flag": "-aesKey",
      "description": "AES key"
    },
    {
      "name": "dc_ip",
      "type": "string",
      "flag": "-dc-ip",
      "description": "Domain controller IP"
    },
    {
      "name": "just_dc",
      "type": "bool",
      "flag": "-just-dc",
      "description": "Dump only domain data"
    },
    {
      "name": "just_dc_user",
      "type": "string",
      "flag": "-just-dc-user",
      "description": "Dump only one domain user"
    },
    {
      "name": "outputfile",
      "type": "string",
      "flag": "-outputfile",
      "path_policy": "work_dir_output",
      "description": "Output prefix in work dir"
    },
    {
      "name": "use_vss",
      "type": "bool",
      "flag": "-use-vss",
      "description": "Fallback to VSS"
    },
    {
      "name": "target",
      "type": "string",
      "required": true,
      "position": 100,
      "description": "domain/user:pass@host or user:pass@host"
    }
  ],
  "examples": [
    {
      "label": "basic",
      "skill_args": {
        "target": "administrator:Passw0rd!@10.10.10.42"
      }
    },
    {
      "label": "dc_user",
      "skill_args": {
        "target": "corp.local/administrator:Passw0rd!@dc01.corp.local",
        "dc_ip": "10.10.10.10",
        "just_dc_user": "administrator",
        "outputfile": "dump_admin"
      }
    }
  ],
  "summary": "使用 `impacket-secretsdump` 导出主机或域控上的哈希、LSA secrets 和目录凭据材料。",
  "use_when": "已拿到本地管理员、域管或可复用的高权限凭据。 需要快速判断目标上是否还有更高价值的哈希或票据材料。 已确认这是后利用阶段，不再是首轮侦察。",
  "command_mode": "argv"
}
