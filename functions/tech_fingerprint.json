{
  "name": "tech_fingerprint",
  "bin": "whatweb",
  "description": "Run WhatWeb with structured fingerprint options.",
  "base_argv": [
    "--color=never"
  ],
  "primary_locator_arg": "url",
  "shape_signature_args": [
    "url",
    "aggression"
  ],
  "variant_signature_args": [
    "url",
    "aggression",
    "max_threads",
    "headers",
    "user_agent",
    "cookie",
    "follow_redirect",
    "plugins",
    "log_json",
    "quiet"
  ],
  "args": [
    {
      "name": "aggression",
      "type": "int",
      "flag": "-a",
      "default": 1,
      "enum": [
        1,
        3,
        4
      ],
      "description": "WhatWeb aggression level"
    },
    {
      "name": "max_threads",
      "type": "int",
      "flag": "-t",
      "description": "Maximum threads"
    },
    {
      "name": "headers",
      "type": "string_list",
      "flag": "-H",
      "repeatable": true,
      "description": "Extra HTTP headers"
    },
    {
      "name": "user_agent",
      "type": "string",
      "flag": "-U",
      "description": "User-Agent override"
    },
    {
      "name": "cookie",
      "type": "string",
      "flag": "-c",
      "description": "Cookie string"
    },
    {
      "name": "follow_redirect",
      "type": "string",
      "flag": "--follow-redirect",
      "description": "Redirect policy"
    },
    {
      "name": "plugins",
      "type": "string",
      "flag": "-p",
      "description": "Plugin subset"
    },
    {
      "name": "log_json",
      "type": "string",
      "flag": "--log-json",
      "path_policy": "work_dir_output",
      "description": "Write JSON log to work dir"
    },
    {
      "name": "quiet",
      "type": "bool",
      "flag": "-q",
      "description": "Reduce terminal noise"
    },
    {
      "name": "url",
      "type": "string",
      "required": true,
      "position": 100,
      "description": "Target URL"
    }
  ],
  "examples": [
    {
      "label": "basic",
      "skill_args": {
        "url": "http://target.local"
      }
    },
    {
      "label": "log_json",
      "skill_args": {
        "url": "http://target.local",
        "aggression": 3,
        "headers": [
          "Cookie: PHPSESSID=demo"
        ],
        "log_json": "whatweb.json"
      }
    }
  ],
  "summary": "使用 `whatweb` 对站点做低成本技术指纹识别，确认框架、中间件、容器、CMS 和常见版本线索。",
  "use_when": "Web 目标首轮侦察，需要先建立技术栈画像。 需要给 `exploit_search`、目录枚举或漏洞验证提供组件线索。 还不知道目标是 PHP、Java、Node、CMS 还是其它技术栈。",
  "command_mode": "argv"
}
